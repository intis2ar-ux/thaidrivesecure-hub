rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // Dashboard users - each user can only read/write their own document
    match /userWdboard/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ✅ NEW ORDERS COLLECTION
    match /orders/{docId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Status activity logs
      match /status_logs/{logId} {
        allow read, create: if request.auth != null;
      }
    }

    // ✅ COUNTER FOR TDS-001 / TDS-002
    match /counters/{docId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Insurance orders
    match /insurance_orders/{docId} {
      // ✅ TEMP: allow create for development / payment upload
      allow create: if true;

      // ✅ TEMP: allow read for development
      allow read: if true;

      // ✅ TEMP: allow update for payment receipt + status update
      allow update: if true;

      // Optional: allow delete only by owner
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Status activity logs
      match /status_logs/{logId} {
        allow read, create: if request.auth != null;
      }
    }

  }

}
