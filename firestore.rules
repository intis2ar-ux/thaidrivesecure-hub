rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // Helper: check if the requesting user has admin role in userWdboard
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/userWdboard/$(request.auth.uid))
        && get(/databases/$(database)/documents/userWdboard/$(request.auth.uid)).data.role == 'admin';
    }

    // Dashboard users - each user can only read/write their own document
    match /userWdboard/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ✅ ORDERS COLLECTION (sole source of truth)
    match /orders/{docId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      // ✅ Only admins can delete (audit-logged in app code)
      allow delete: if isAdmin();

      // Status activity logs (payment verification history, status changes)
      match /status_logs/{logId} {
        allow read, create: if true;
        allow update, delete: if false;
      }
    }

    // ✅ AUDIT LOGS — append-only record of admin actions (deletions, etc.)
    match /audit_logs/{logId} {
      // Any authenticated dashboard user can read audit history
      allow read: if request.auth != null;
      // Any authenticated user can create a log entry (server-side validation lives in app code)
      allow create: if request.auth != null;
      // Audit logs are immutable
      allow update, delete: if false;
    }

    // ✅ COUNTER FOR TDS-001 / TDS-002
    match /counters/{docId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if false;
    }

  }

}
