rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // Dashboard users - each user can only read/write their own document
    match /userWdboard/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ✅ ORDERS COLLECTION (sole source of truth)
    match /orders/{docId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Status activity logs (payment verification history, status changes)
      match /status_logs/{logId} {
        allow read, create: if true;
        allow update, delete: if false;
      }
    }

    // ✅ COUNTER FOR TDS-001 / TDS-002
    match /counters/{docId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if false;
    }

  }

}
